   ],
   "source": [
    "p = float(input(\"Enter your principal\"))\n",
    "r = float(input(\"Enter your rate in %\"))\n",
    "t = float(input(\"Enter your time(in years)\")) \n",
    "n = float(input(\"Enter your interest number\"))\n",
    "\n",
    "a = p*((1.0 + (r/n)**(n*t)) - 1.0)/(r/n)\n",
    "\n",
    "print(f\"The annuity plan is {a:.2f}\")"
   ]
  },
